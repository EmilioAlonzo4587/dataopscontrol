# ─────────────────────────────────────────────────────────────
# DataOps Control Center — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=dataops
POSTGRES_PASSWORD=dataops123
POSTGRES_DB=dataops_primary

# SQL Server
MSSQL_SA_PASSWORD=DataOps123!

# Security
SECRET_KEY=supersecretkey_dataops_2024_change_in_prod_please

# AWS S3 Backup
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=dataops-backups-your-org

# SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_EMAIL_TO=admin@yourorg.com

# Grafana
GRAFANA_PASSWORD=admin123

# Environment
ENVIRONMENT=development
